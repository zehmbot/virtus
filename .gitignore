# ─────────────────────────────────────────────────────────────
#  Virtus — .gitignore
#  Secrets and live agent state must NEVER be committed.
# ─────────────────────────────────────────────────────────────

.env
.env.*
!.env.example
*.key
*.pem
secrets/
auth.json

# --- Goose live state (holds secrets.yaml, OAuth tokens, memory, sessions) ---
goose-home/

# --- Mounted project workspaces (agents work on external repos) --------------
# Keep the folder, ignore whatever gets mounted/checked out inside it.
projects/*
!projects/.gitkeep

__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.uv/

node_modules/
dist/
build/
*.tsbuildinfo
.npm/

*.log

.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
