# ─────────────────────────────────────────────────────────────
#  Virtus — environment template
# ─────────────────────────────────────────────────────────────

# --- Model provider API keys (fill in only the providers you use) ------------
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Goose: which provider/model the crew uses -------------------------------
# Provider id, e.g. anthropic | openai | google | ollama | openrouter
GOOSE_PROVIDER=
# Model id for that provider, e.g. claude-sonnet-5 / gpt-5 / gemini-3.1-flash-lite
GOOSE_MODEL=

# --- Build settings ----------------------------------------------------------
# Goose release to build (see the Dockerfile ARG). Format: X.Y.Z
GOOSE_VERSION=1.43.0
