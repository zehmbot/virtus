# ─────────────────────────────────────────────────────────────
#  Virtus — environment template
#  Copy to `.env` and fill in only what you use.  `.env` is gitignored.
# ─────────────────────────────────────────────────────────────

# --- Model provider API keys (fill in only the providers you use) ------------
# Anthropic (Claude) — API-key auth
ANTHROPIC_API_KEY=

# OpenRouter — multi-model aggregator
OPENROUTER_API_KEY=

# OpenAI — NOTE: this is the pay-per-token API, billed separately from a
# ChatGPT Plus/Pro subscription. A ChatGPT subscription does NOT cover it.
OPENAI_API_KEY=

# Google (Gemini) — has a free tier, handy for zero-cost testing
GOOGLE_API_KEY=

# --- Goose: which provider/model the crew uses -------------------------------
# Provider id, e.g. anthropic | openai | google | ollama | openrouter
GOOSE_PROVIDER=
# Model id for that provider, e.g. claude-sonnet-5 / gpt-5 / gemini-2.5-pro
GOOSE_MODEL=
# Tip: no key at all? Run models locally with Ollama for a $0 setup.
# Tip: each agent has its own config, so agents can use different providers.

# --- Subscription / OAuth providers ------------------------------------------
# Nous Portal, MiniMax, and other subscription logins do NOT use a key here.
# Authenticate interactively inside the container instead, e.g.:
#     docker exec -it virtus hermes -p <profile> setup --portal
# The resulting auth.json is stored under /opt/data (the mounted volume) and
# persists across restarts.

# --- Build settings ----------------------------------------------------------
# Upstream Hermes Agent release to build (see the Dockerfile ARG).
HERMES_VERSION=v2026.7.7.2

# Goose release to build (see the Dockerfile.goose ARG). Format: X.Y.Z
GOOSE_VERSION=1.43.0
